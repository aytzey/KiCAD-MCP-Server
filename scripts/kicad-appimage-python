#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

find_appdir() {
  if [[ -n "${KICAD_APPDIR:-}" && -x "${KICAD_APPDIR}/AppRun" ]]; then
    printf '%s\n' "${KICAD_APPDIR}"
    return 0
  fi

  local candidate
  for candidate in "${HOME}/.local/opt/kicad-10.0.0/AppDir" "${HOME}"/.local/opt/kicad-*/AppDir; do
    if [[ -x "${candidate}/AppRun" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

find_python_name() {
  local candidate
  for candidate in python3.13 python3.12 python3.11 python3.10 python3; do
    if [[ -x "${APPDIR}/bin/${candidate}" || -x "${APPDIR}/shared/bin/${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

APPDIR="$(find_appdir)" || {
  printf 'KiCad AppImage AppDir not found.\n' >&2
  exit 1
}

PYTHON_NAME="$(find_python_name)" || {
  printf 'No KiCad AppImage Python executable found under %s.\n' "${APPDIR}" >&2
  exit 1
}

BOOTSTRAP="${PROJECT_ROOT}/python/utils/appimage_python_bootstrap.py"
exec "${APPDIR}/AppRun" "${PYTHON_NAME}" "${BOOTSTRAP}" "$@"
